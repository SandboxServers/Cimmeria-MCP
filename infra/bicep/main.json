    "searchEndpoint": {
      "type": "string",
      "value": "[if(parameters('deploySearch'), format('https://{0}.search.windows.net', parameters('searchServiceName')), '')]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[if(parameters('deployShowcase'), reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri, '')]"
    },
    "appConfigEndpoint": {
      "type": "string",
      "value": "[if(parameters('deployShowcase'), reference(resourceId('Microsoft.AppConfiguration/configurationStores', parameters('appConfigName')), '2023-03-01').endpoint, '')]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'full').identity.principalId]"
    },
    "staticSiteUrl": {
      "type": "string",
      "value": "[if(parameters('deployShowcase'), format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', parameters('staticSiteName')), '2023-12-01').defaultHostname), '')]"
    }
  }
}