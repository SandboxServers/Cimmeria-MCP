# Cimmeria-MCP colo deployment — environment contract.
#
# Copy to `.env` in this directory and fill in the values that match
# your colo + Azure setup. The compose file reads from `.env`
# automatically when invoked with `--env-file .env`. None of these
# values should be committed back to git — `.env` is in .gitignore.

# ── Database ──────────────────────────────────────────────────────
# Postgres password for the `mcp` user. The pgvector container
# initialises with this on first run; subsequent restarts reuse the
# password from the persisted data volume.
#
# Generate: `openssl rand -base64 24`
POSTGRES_PASSWORD=

# ── Azure OpenAI (the one remaining cloud dependency) ─────────────
# Resource endpoint and key. Pulled from your Azure portal under
# the OpenAI resource → Keys and Endpoint. The MCP server calls out
# to Azure for embeddings + chat completions on every search-side
# request, so this needs to be live for the deployment to function.
OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
OPENAI_KEY=

# Deployment names — match the deployment slot names you created in
# the Azure OpenAI Studio. Defaults below align with the names
# documented in CLAUDE.md for the current cloud deployment.
OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
OPENAI_CHAT_DEPLOYMENT=gpt-5.1-chat
OPENAI_CODEX_DEPLOYMENT=gpt-5.1-codex-mini

# ── MCP HTTP auth ─────────────────────────────────────────────────
# Bearer token the MCP client presents on every request. Replaces
# Azure Functions' `x-functions-key` header.
#
# Generate: `openssl rand -hex 32`
MCP_API_KEY=

# Bind address for the MCP HTTP endpoint on the host. Default is
# loopback only — front it with the Cloudflare Tunnel that exposes
# the SigNoz UI if you want remote LLM-client access. Set to
# `0.0.0.0` only behind a LAN firewall.
MCP_BIND=127.0.0.1

# ── SigNoz network ────────────────────────────────────────────────
# Cimmeria's compose project creates a default docker network when
# its stack starts. The MCP container joins that network so it can
# reach `otel-collector:4317` by DNS. The default `cimmeria_default`
# matches a Cimmeria compose project named "cimmeria" (i.e. brought
# up from a directory called `cimmeria/` or with `--project-name
# cimmeria`). Override if your project name differs.
#
# Inspect on the host with: `docker network ls`
SIGNOZ_NETWORK_NAME=cimmeria_default
